#!/usr/bin/env bash
# generar_alloc
# Recorre el directorio private, lee los ficheros address y key de cada
# subdirectorio y genera private/qbftConfigFile.json a partir de la plantilla
# templates/qbftConfigFile.json, añadiendo entradas en la clave "alloc".

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

TEMPLATE="${REPO_ROOT}/templates/qbftConfigFile.json"
PRIVATE_DIR="${REPO_ROOT}/private"
DIRECCIONES_DIR="${PRIVATE_DIR}/direcciones"
OUTPUT="${PRIVATE_DIR}/qbftConfigFile.json"

BALANCE="90000000000000000000000"

# Comprobaciones previas
if ! command -v jq &>/dev/null; then
    echo "ERROR: jq no está instalado. Instálalo con: brew install jq" >&2
    exit 1
fi

if [[ ! -f "${TEMPLATE}" ]]; then
    echo "ERROR: No se encuentra la plantilla ${TEMPLATE}" >&2
    exit 1
fi

# Partir de la plantilla (con alloc vacío)
cp "${TEMPLATE}" "${OUTPUT}"

# Recorrer subdirectorios de private/direcciones/
for dir in "${DIRECCIONES_DIR}"/*/; do
    # Ignorar si no es un directorio real
    [[ -d "${dir}" ]] || continue

    subdir_name="$(basename "${dir}")"
    address_file="${dir}address"
    key_file="${dir}key"

    if [[ ! -f "${address_file}" ]]; then
        echo "AVISO: No existe ${address_file}, saltando ${subdir_name}" >&2
        continue
    fi

    if [[ ! -f "${key_file}" ]]; then
        echo "AVISO: No existe ${key_file}, saltando ${subdir_name}" >&2
        continue
    fi

    address="$(tr -d '[:space:]' <"${address_file}")"
    private_key="$(tr -d '[:space:]' <"${key_file}")"

    echo "Procesando ${subdir_name}: address=${address}"

    # Añadir la entrada al objeto alloc usando jq
    OUTPUT_TMP="$(mktemp)"
    jq \
        --arg addr "${address}" \
        --arg pk "${private_key}" \
        --arg comment "${subdir_name}" \
        --arg balance "${BALANCE}" \
        '.genesis.alloc[$addr] = {
       "privateKey": $pk,
       "comment":    $comment,
       "balance":    $balance
     }' \
        "${OUTPUT}" >"${OUTPUT_TMP}"

    mv "${OUTPUT_TMP}" "${OUTPUT}"
done

echo ""
echo "Fichero generado: ${OUTPUT}"
